rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── Security Helper Functions ───
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ─── 1. Admins Collection ───
    match /admins/{adminId} {
      allow read: if isAuthenticated() && request.auth.uid == adminId;
      allow write: if false; // Managed exclusively by Cloud Functions
    }

    // ─── 2. Users / Customers ───
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if false; // Created exclusively by Cloud Function (createCustomer)
      allow update: if isAdmin();
      allow delete: if false; // Soft deletes only (isActive: false)
    }

    // ─── 3. Products Catalog ───
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── 4. Inventory Ledger ───
    match /inventory/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin(); // Cloud Functions also update this via Admin SDK
    }

    // ─── 5. Orders ───
    match /orders/{orderId} {
      allow read: if isOwner(resource.data.customerId) || isAdmin();
      allow create: if false; // Created exclusively by Cloud Function (placeSecureOrder)
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // ─── 6. Invoices ───
    match /invoices/{invoiceId} {
      allow read: if isOwner(resource.data.customerId) || isAdmin();
      allow write: if isAdmin();
    }

    // ─── 7. Categories ───
    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── 8. Audit Logs (Read-only for admins, written by Cloud Functions) ───
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Written exclusively by Cloud Functions via Admin SDK
    }
  }
}
