rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Security Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. Admins Collection (Separate from Users)
    match /admins/{adminId} {
      // Any authenticated user can read their own admin doc (needed for login check)
      allow read: if isAuthenticated() && request.auth.uid == adminId;
      // No one can write from the client — admins are added manually in the Firebase Console
      allow write: if false;
    }

    // 2. Users / Customers (Retailers, Distributors)
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin(); // Only admins can create/approve customers
    }

    // 3. Products Catalog
    match /products/{productId} {
      allow read: if isAuthenticated(); // Any logged-in retailer can browse
      allow write: if isAdmin(); // Admins only (pricing, stock management)
    }

    // 3.5. Inventory Ledger
    match /inventory/{productId} {
      allow read: if isAuthenticated(); // Retailers need to know if item is in stock
      allow write: if isAdmin(); // Admins manage stock. (Cloud functions will handle automated deductions later)
    }

    // 4. Orders (No Payment Gateway - Offline tracking)
    match /orders/{orderId} {
      // Retailers can read their own orders. Admins can read all.
      allow read: if isOwner(resource.data.customerId) || isAdmin();
      
      // Orders MUST be placed via Cloud Function (placeSecureOrder)
      allow create: if false; 
      
      // Only admins can update status (Confirmed -> Dispatched -> Delivered)
      allow update, delete: if isAdmin();
    }
    
    // 6. Invoices
    match /invoices/{invoiceId} {
      allow read: if isOwner(resource.data.customerId) || isAdmin();
      allow write: if isAdmin();
    }

    // 7. Categories
    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
